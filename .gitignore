# Claude Code per-machine settings (contains absolute paths, never share)
.claude/settings.local.json

# Skill runtime artifacts (the project-scaffolder skill creates these in
# scaffolded projects; including them here is belt-and-suspenders so they
# never accidentally land in this repo)
.worktrees/
.scaffold-state.json

# Environment files — never commit secrets
.env
.env.*
!.env.example

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# Logs / dumps that commonly leak when debugging
*.log
*.dump
core
core.*
